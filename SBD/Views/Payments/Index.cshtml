@using System.Data
@{
    ViewData["Title"] = "Zarządzanie finansami";
    var payments = ViewBag.Payments as List<Payment>;
    var penalties = ViewBag.Penalties as List<Penalty>;
    var rentals = ViewBag.Rentals as List<Rental>;
    var clients = ViewBag.Clients as List<Client>;
}

<div class="page-header-container">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-credit-card"></i> Zarządzanie <span class="gradient-text">Finansami</span></h1>
        <p class="page-subtitle">Kontroluj wpłaty ratalne, księguj płatności jednorazowe oraz nakładaj kary na klientów.</p>
    </div>
</div>

<div class="financial-dashboard-grid">
    <!-- Left Panel: Lists (Tabs: Payments / Penalties) -->
    <div class="financial-main-panel glass-card">
        <div class="tabs-header">
            <button class="tab-btn active" onclick="switchFinTab('payments-tab')">
                <i class="fa-solid fa-receipt"></i> Płatności i Raty
            </button>
            <button class="tab-btn" onclick="switchFinTab('penalties-tab')">
                <i class="fa-solid fa-triangle-exclamation"></i> Nałożone kary
            </button>
        </div>

        <div class="tab-content" id="payments-tab">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Wypożyczenie</th>
                            <th>Kwota</th>
                            <th>Termin/Metoda</th>
                            <th class="text-center">Rata</th>
                            <th class="text-center">Status</th>
                            <th class="text-right">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (payments != null && payments.Count > 0)
                        {
                            foreach (var pay in payments)
                            {
                                string statusClass = pay.StatusName == "PAID" ? "badge-available" : "badge-warning";
                                <tr>
                                    <td><strong>#@pay.PaymentId</strong></td>
                                    <td>
                                        <div class="text-white font-medium">Wypożyczenie #@pay.RentalId</div>
                                    </td>
                                    <td class="text-teal font-semibold">@pay.Amount.ToString("N2") PLN</td>
                                    <td>
                                        @if (pay.PaymentDate.HasValue)
                                        {
                                            <div>Opłacono: @pay.PaymentDate.Value.ToString("yyyy-MM-dd")</div>
                                            <div class="text-muted font-sm">Metoda: @pay.PaymentMethod</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted italic">Oczekiwanie na wpłatę</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (pay.TotalInstallments > 1)
                                        {
                                            <span class="badge badge-multiplier-high">@pay.InstallmentNo / @pay.TotalInstallments</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Jednorazowa</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @statusClass">@pay.StatusName</span>
                                    </td>
                                    <td class="text-right">
                                        @if (pay.StatusName == "PENDING")
                                        {
                                            <form asp-action="PayInstallment" asp-route-id="@pay.PaymentId" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-cash-register"></i> Opłać</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted font-sm"><i class="fa-solid fa-circle-check text-teal"></i> Zrealizowano</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">Brak transakcji płatniczych w bazie danych.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-content" id="penalties-tab" style="display:none;">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>ID kary</th>
                            <th>Klient</th>
                            <th>Wypożyczenie</th>
                            <th>Powód kary</th>
                            <th>Kwota kary</th>
                            <th>Data naliczenia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (penalties != null && penalties.Count > 0)
                        {
                            foreach (var pen in penalties)
                            {
                                <tr>
                                    <td><strong>#@pen.PenaltyId</strong></td>
                                    <td>
                                        <div class="text-white font-medium">@pen.ClientName</div>
                                        <div class="text-muted font-sm">ID klienta: #@pen.ClientId</div>
                                    </td>
                                    <td>
                                        @(pen.RentalId.HasValue ? $"Wypożyczenie #{pen.RentalId.Value}" : "-")
                                    </td>
                                    <td>@pen.Reason</td>
                                    <td class="text-red font-bold">@pen.Amount.ToString("N2") PLN</td>
                                    <td>@pen.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">Brak zarejestrowanych kar dla klientów.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Panel: Financial Quick Actions -->
    <div class="financial-actions-panel">
        <!-- Action 1: Zaksięguj płatność -->
        <div class="glass-card action-card-fin mb-4 animate-slide-up">
            <div class="action-card-header">
                <h4><i class="fa-solid fa-cash-register text-teal"></i> Zaksięguj płatność jednorazową</h4>
            </div>
            <form asp-action="ProcessPayment" method="post" class="action-card-body">
                <div class="form-group">
                    <label for="rentalId">Wypożyczenie</label>
                    <select name="rentalId" class="form-control control-sm" required>
                        <option value="">Wybierz wypożyczenie...</option>
                        @if (rentals != null)
                        {
                            foreach (var rental in rentals.FindAll(r => r.Status == "ACTIVE"))
                            {
                                <option value="@rental.RentalId">#@rental.RentalId - @rental.ClientName | @rental.CarName</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label for="amount">Kwota (PLN)</label>
                        <input type="number" step="0.01" name="amount" class="form-control control-sm" placeholder="np. 150.00" required />
                    </div>
                    <div class="form-group">
                        <label for="paymentMethod">Metoda</label>
                        <select name="paymentMethod" class="form-control control-sm">
                            <option value="CARD">Karta (CARD)</option>
                            <option value="CASH">Gotówka (CASH)</option>
                            <option value="TRANSFER">Przelew (TRANSFER)</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-teal btn-sm btn-block mt-3"><i class="fa-solid fa-dollar-sign"></i> Zaksięguj wpłatę</button>
            </form>
        </div>

        <!-- Action 2: Rozłóż na raty -->
        <div class="glass-card action-card-fin mb-4 animate-slide-up" style="animation-delay: 0.1s;">
            <div class="action-card-header">
                <h4><i class="fa-solid fa-file-invoice-dollar text-purple"></i> Utwórz plan ratalny</h4>
            </div>
            <form asp-action="CreateInstallments" method="post" class="action-card-body">
                <div class="form-group">
                    <label for="rentalId">Wypożyczenie</label>
                    <select name="rentalId" class="form-control control-sm" required>
                        <option value="">Wybierz wypożyczenie...</option>
                        @if (rentals != null)
                        {
                            foreach (var rental in rentals.FindAll(r => r.Status == "ACTIVE"))
                            {
                                <option value="@rental.RentalId">#@rental.RentalId - @rental.ClientName | Stawka: @rental.TotalPrice.ToString("N0") PLN</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="installments">Liczba rat</label>
                    <select name="installments" class="form-control control-sm">
                        <option value="3">3 raty</option>
                        <option value="6">6 rat</option>
                        <option value="12">12 rat</option>
                        <option value="2">2 raty</option>
                        <option value="4">4 raty</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-purple btn-sm btn-block mt-3"><i class="fa-solid fa-calculator"></i> Generuj harmonogram rat</button>
            </form>
        </div>

        <!-- Action 3: Nalicz karę -->
        <div class="glass-card action-card-fin animate-slide-up" style="animation-delay: 0.2s;">
            <div class="action-card-header">
                <h4><i class="fa-solid fa-circle-exclamation text-red"></i> Nalicz karę klientowi</h4>
            </div>
            <form asp-action="AddPenalty" method="post" class="action-card-body">
                <div class="form-group">
                    <label for="clientId">Wybierz klienta</label>
                    <select name="clientId" class="form-control control-sm" required>
                        <option value="">Wybierz klienta...</option>
                        @if (clients != null)
                        {
                            foreach (var client in clients)
                            {
                                <option value="@client.ClientId">#@client.ClientId - @client.FirstName @client.LastName</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="rentalId">Powiązane wypożyczenie (opcjonalnie)</label>
                    <select name="rentalId" class="form-control control-sm">
                        <option value="">-- Brak powiązania --</option>
                        @if (rentals != null)
                        {
                            foreach (var rental in rentals)
                            {
                                <option value="@rental.RentalId">Wypożyczenie #@rental.RentalId (@rental.CarName)</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="reason">Powód kary</label>
                    <input type="text" name="reason" class="form-control control-sm" placeholder="np. Uszkodzenie zderzaka, spóźnienie" required />
                </div>
                <div class="form-group">
                    <label for="amount">Kwota kary (PLN)</label>
                    <input type="number" step="0.01" name="amount" class="form-control control-sm" placeholder="np. 250.00" required />
                </div>
                <button type="submit" class="btn btn-danger btn-sm btn-block mt-3"><i class="fa-solid fa-triangle-exclamation"></i> Nalicz karę</button>
            </form>
        </div>
    </div>
</div>
