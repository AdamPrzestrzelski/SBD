@model SBD.Models.Car
@{
    ViewData["Title"] = "Dodaj pojazd";
}

<div class="page-header-container">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-car"></i> Dodaj <span class="gradient-text">Pojazd</span></h1>
        <p class="page-subtitle">Uzupełnij poniższy formularz, aby dodać nowy pojazd do floty.</p>
    </div>
    <a asp-action="Index" class="btn btn-muted"><i class="fa-solid fa-arrow-left"></i> Powrót</a>
</div>

<div class="form-container-centered">
    <div class="glass-card form-card animate-slide-up">
        <div class="card-header">
            <h3><i class="fa-solid fa-circle-info text-teal"></i> Informacje o pojeździe</h3>
        </div>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="form-validation-summary text-danger"></div>
            
            <div class="form-grid-2">
                <div class="form-group">
                    <label asp-for="Brand" class="form-label">Marka <span class="text-danger">*</span></label>
                    <input asp-for="Brand" class="form-control" placeholder="np. Toyota" required />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="form-label">Model <span class="text-danger">*</span></label>
                    <input asp-for="Model" class="form-control" placeholder="np. Corolla" required />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-3">
                <div class="form-group">
                    <label asp-for="Year" class="form-label">Rok produkcji <span class="text-danger">*</span></label>
                    <input asp-for="Year" type="number" class="form-control" value="2025" min="1990" max="2030" required />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Seats" class="form-label">Miejsca</label>
                    <input asp-for="Seats" type="number" class="form-control" value="5" min="1" max="9" required />
                    <span asp-validation-for="Seats" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Color" class="form-label">Kolor</label>
                    <input asp-for="Color" class="form-control" placeholder="np. Czarny" />
                    <span asp-validation-for="Color" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label asp-for="PlateNumber" class="form-label">Numer rejestracyjny <span class="text-danger">*</span></label>
                    <input asp-for="PlateNumber" class="form-control" placeholder="np. WE12345" required />
                    <span asp-validation-for="PlateNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Vin" class="form-label">Numer VIN <span class="text-danger">*</span></label>
                    <input asp-for="Vin" class="form-control" placeholder="17-znakowy numer VIN" required />
                    <span asp-validation-for="Vin" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label asp-for="DailyRate" class="form-label">Cena za dobę (PLN) <span class="text-danger">*</span></label>
                    <input asp-for="DailyRate" type="number" step="0.01" class="form-control" value="150.00" required />
                    <span asp-validation-for="DailyRate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Mileage" class="form-label">Aktualny przebieg (km) <span class="text-danger">*</span></label>
                    <input asp-for="Mileage" type="number" class="form-control" value="10000" min="0" required />
                    <span asp-validation-for="Mileage" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label asp-for="CategoryId" class="form-label">Kategoria pojazdu <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-control" required>
                        <option value="">Wybierz kategorię...</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in (List<CarCategory>)ViewBag.Categories)
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BranchId" class="form-label">Oddział przypisania <span class="text-danger">*</span></label>
                    <select asp-for="BranchId" class="form-control" required>
                        <option value="">Wybierz oddział...</option>
                        @if (ViewBag.Branches != null)
                        {
                            foreach (var branch in (List<Branch>)ViewBag.Branches)
                            {
                                <option value="@branch.BranchId">@branch.Name (@branch.City)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions-row">
                <button type="reset" class="btn btn-muted">Wyczyść</button>
                <button type="submit" class="btn btn-primary btn-glow"><i class="fa-solid fa-save"></i> Zapisz pojazd</button>
            </div>
        </form>
    </div>
</div>
