<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <connectionStrings>
        <!-- 
            Konfiguracja połączenia z Oracle Database.
            Zmień poniższe wartości na właściwe dla Twojego środowiska:
            - HOST: adres serwera Oracle (np. localhost, 213.184.8.44)
            - PORT: port Oracle (domyślnie 1521)
            - SERVICE_NAME: nazwa serwisu (np. ORCL, XE, FREEPDB1)
            - User Id / Password: dane logowania
        -->
        <add name="OracleDb" 
             connectionString="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)));User Id=SBD_USER;Password=SBD_PASSWORD;" 
             providerName="Oracle.ManagedDataAccess.Client" />
    </connectionStrings>
</configuration>